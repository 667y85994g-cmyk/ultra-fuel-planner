# Ultra Fuel Planner — environment variables
#
# Copy this file to .env.local and fill in your values.
# NEXT_PUBLIC_ prefix = exposed to the browser (intentional for GA4).

# Google Analytics 4 Measurement ID
# Found in: GA4 Admin → Data Streams → your web stream → Measurement ID
# Format: G-XXXXXXXXXX
# Leave blank in development to suppress all GA4 calls.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
